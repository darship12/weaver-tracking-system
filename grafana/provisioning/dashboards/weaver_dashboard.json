{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Weaver Employee Tracking Dashboard",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short"}
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "title": "Total Employees",
      "type": "stat",
      "targets": [{"datasource": "PostgreSQL", "format": "table", "rawSql": "SELECT COUNT(*) as value FROM employee_employee WHERE status = 'active'", "refId": "A"}]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "none"}
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Today's Production (meters)",
      "type": "stat",
      "targets": [{"datasource": "PostgreSQL", "rawSql": "SELECT COALESCE(SUM(meter_woven), 0) as value FROM production_production WHERE date = CURRENT_DATE", "refId": "A"}]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 10, "lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 4},
      "id": 3,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}},
      "title": "Daily Production (Last 30 Days)",
      "type": "timeseries",
      "targets": [{
        "datasource": "PostgreSQL",
        "rawSql": "SELECT date AS \"time\", SUM(meter_woven) AS \"Meters Woven\" FROM production_production WHERE date >= NOW() - INTERVAL '30 days' GROUP BY date ORDER BY date",
        "refId": "A",
        "format": "time_series"
      }]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {"defaults": {"unit": "currencyINR"}},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Monthly Payroll",
      "type": "stat",
      "targets": [{"datasource": "PostgreSQL", "rawSql": "SELECT COALESCE(SUM(total_salary), 0) as value FROM salary_salary WHERE month = EXTRACT(MONTH FROM NOW()) AND year = EXTRACT(YEAR FROM NOW())", "refId": "A"}]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {"defaults": {"custom": {"align": "auto"}}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 5,
      "options": {"footer": {"show": false}, "showHeader": true},
      "title": "Top Performers This Month",
      "type": "table",
      "targets": [{
        "datasource": "PostgreSQL",
        "rawSql": "SELECT e.employee_id, e.name, e.skill_level, SUM(p.meter_woven) as total_meters, COUNT(p.id) as working_days FROM production_production p JOIN employee_employee e ON p.employee_id = e.id WHERE EXTRACT(MONTH FROM p.date) = EXTRACT(MONTH FROM NOW()) AND EXTRACT(YEAR FROM p.date) = EXTRACT(YEAR FROM NOW()) GROUP BY e.id, e.employee_id, e.name, e.skill_level ORDER BY total_meters DESC LIMIT 10",
        "format": "table",
        "refId": "A"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["weaver"],
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Weaver Tracking Dashboard",
  "uid": "weaver-main",
  "version": 1
}
